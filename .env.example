# Copy this file to .env and fill in your values.
# The app works without any key — all features gracefully degrade.

# ── Sarvam AI (optional) ──────────────────────────────────────────────────────
# Enables AI-powered market assumptions + customer segment generation.
# Get a free key at: https://dashboard.sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here

# Model to use (default: sarvam-m)
# SARVAM_MODEL=sarvam-m

# ── Neo4j (optional) ───────────────────────────────────────────────────────────
# Stores population nodes after each simulation for the Graph tab.
# Install Neo4j Desktop (free): https://neo4j.com/download/
# After installing, create a database and set the password below.
#
# Default values work with a locally running Neo4j instance.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=vingel_password

# Set to "false" to disable Neo4j even if it's running
# USE_NEO4J=true

# ── Monad Blockchain (optional) ───────────────────────────────────────────────
# For anchoring simulation proofs and on-chain balance-gating.
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CONTRACT_ADDRESS=
MONAD_PRIVATE_KEY=
MONAD_SIMGATE_ADDRESS=

